---
import { t, type Locale } from "@i18n/index";
import { skills } from "@data/skills";
import SkillsBoard from "@components/home/SkillsBoard.tsx";
import Icon from "@components/ui/Icon.astro";

interface Props {
    locale: Locale;
}
const { locale } = Astro.props;
---

<section id="skills" class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
    <div class="mb-12 flex items-end justify-between flex-wrap gap-4">
        <div>
            <p class="eyebrow reveal mb-4">{t("skills.eyebrow", locale)}</p>
            <h2
                class="reveal text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05] text-text-primary"
                data-delay="1"
            >
                {t("skills.heading", locale)}
            </h2>
            <p
                class="reveal mt-4 text-base md:text-lg max-w-2xl text-text-secondary"
                data-delay="2"
            >
                {t("skills.description", locale)}
            </p>
        </div>
        <div
            class="reveal hidden md:flex items-center gap-4 font-mono text-xs text-text-disabled"
            data-delay="3"
        >
            <span class="inline-flex items-center gap-2">
                <span class="status-dot"></span>
                {t("skills.hoverHint", locale)}
            </span>
        </div>
    </div>

    <div class="reveal" data-delay="2">
        <SkillsBoard ecosystems={skills} locale={locale} client:visible />
    </div>
</section>
