---
import { t, tInterpolate, type Locale } from "@i18n/index";
import { siteConfig } from "@data/site";
import Button from "@components/ui/Button.astro";
import Icon from "@components/ui/Icon.astro";

interface Props {
    locale: Locale;
}
const { locale } = Astro.props;
---

<section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-bg opacity-40 pointer-events-none"></div>

    <div
        class="absolute -top-40 left-1/3 pointer-events-none size-175"
        style="background:radial-gradient(circle, oklch(0.7 0.15 220 / 0.12) 0%, transparent 70%);"
    >
    </div>

    <div
        class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-16 pb-20 md:pt-24 md:pb-28"
    >
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
            <div class="lg:col-span-7 hero-enter">
                <div class="flex items-center gap-3 mb-7">
                    <span class="eyebrow eyebrow-accent">
                        <span class="status-dot"></span>
                        {t("hero.systemOnline", locale)}
                    </span>
                </div>

                <div class="flex flex-wrap items-center gap-2 mb-8">
                    <span class="eco-node geom-cut-sm eco-node-primary">
                        <span class="indicator"></span>
                        TypeScript
                    </span>
                    <span class="eco-node geom-cut-sm eco-node-success">
                        <span class="indicator" style="animation-delay:0.3s;"
                        ></span>
                        Rust
                    </span>
                    <span class="eco-node geom-cut-sm eco-node-warning">
                        <span class="indicator" style="animation-delay:0.6s;"
                        ></span>
                        Java
                    </span>
                </div>

                <h1
                    class="font-extrabold tracking-tight leading-[0.95] text-text-primary"
                    style="font-size: clamp(2.6rem, 6.5vw, 4.6rem);"
                >
                    {siteConfig.author}
                    <span
                        class="block mt-1 text-accent-primary"
                        style="font-size: 0.55em; font-weight: 600; letter-spacing: -0.01em;"
                    >
                        {t("hero.tagline", locale)}
                    </span>
                </h1>

                <p
                    class="mt-6 text-base md:text-lg leading-relaxed max-w-2xl text-text-secondary"
                >
                    {t("hero.summary", locale)}
                </p>

                <div class="mt-9 flex flex-wrap items-center gap-4">
                    <Button href={`mailto:${siteConfig.email}`} variant="cta">
                        <Icon name="mail" size={18} />
                        {t("hero.sendEmail", locale)}
                        <Icon name="arrow" size={16} />
                    </Button>
                    {
                        siteConfig.cvUrl && (
                            <Button
                                href={siteConfig.cvUrl}
                                variant="secondary"
                                download
                            >
                                <Icon name="download" size={16} />
                                {t("hero.downloadCV", locale)}
                            </Button>
                        )
                    }
                </div>

                <div
                    class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-xs text-text-disabled"
                >
                    <span class="inline-flex items-center gap-1.5">
                        <Icon name="clock" size={12} />
                        {t("hero.timezone", locale)}
                    </span>
                    <span class="text-border-default">·</span>
                    <span class="inline-flex items-center gap-1.5">
                        <Icon name="check" size={12} />
                        {t("hero.respondsIn", locale)}
                    </span>
                    <span class="text-border-default">·</span>
                    <span class="inline-flex items-center gap-1.5">
                        <Icon name="github" size={12} />
                        {tInterpolate("hero.ecosystems", locale, { n: 3 })}
                    </span>
                </div>
            </div>

            <div class="lg:col-span-5 hero-enter">
                <div class="coord-frame-4 p-2">
                    <span class="coord-mark tl"></span>
                    <span class="coord-mark tr"></span>
                    <span class="coord-mark bl"></span>
                    <span class="coord-mark br"></span>

                    <div class="card-wrapper">
                        <div class="terminal geom-cut-lg">
                            <div class="terminal-header">
                                <span
                                    class="terminal-dot"
                                    style="background-color: oklch(0.65 0.2 25);"
                                ></span>
                                <span
                                    class="terminal-dot"
                                    style="background-color: oklch(0.75 0.15 85);"
                                ></span>
                                <span
                                    class="terminal-dot"
                                    style="background-color: oklch(0.7 0.18 145);"
                                ></span>
                                <span class="terminal-title">
                                    {t("hero.stackConfig", locale)}
                                </span>
                                <span
                                    class="ml-auto font-mono text-[0.65rem] inline-flex items-center gap-1.5 text-accent-success"
                                >
                                    <span class="status-dot"></span>
                                    READY
                                </span>
                            </div>

                            <div class="terminal-body">
                                <div class="terminal-scan"></div>

                                <div class="log-line">
                                    <span class="text-text-disabled">$</span>
                                    <span class="text-accent-primary"
                                        >{
                                            t("hero.terminalWhoami", locale)
                                        }</span
                                    >
                                </div>
                                <div class="log-line">
                                    <span class="text-text-secondary"
                                        >→ {siteConfig.author} · {
                                            siteConfig.role
                                        }</span
                                    >
                                </div>

                                <div class="log-line mt-2">
                                    <span class="text-text-disabled">$</span>
                                    <span class="text-accent-primary"
                                        >{t("hero.terminalCat", locale)}</span
                                    >
                                </div>

                                <div class="log-line">
                                    <span class="text-accent-warning"
                                        >[typescript]</span
                                    >
                                    <span class="text-text-secondary"
                                        >react · astro · nestjs</span
                                    >
                                </div>
                                <div class="log-line">
                                    <span class="text-accent-success"
                                        >[rust]</span
                                    >
                                    <span class="text-text-secondary"
                                        >tauri · tokio · serde</span
                                    >
                                </div>
                                <div class="log-line">
                                    <span class="text-accent-primary"
                                        >[java]</span
                                    >
                                    <span class="text-text-secondary"
                                        >spring · maven · hibernate</span
                                    >
                                </div>

                                <div class="log-line mt-2">
                                    <span class="text-text-disabled">$</span>
                                    <span class="text-accent-primary"
                                        >{
                                            t("hero.terminalStatus", locale)
                                        }</span
                                    >
                                </div>
                                <div class="log-line">
                                    <span class="text-accent-success">●</span>
                                    <span class="text-text-secondary"
                                        >{t("hero.accepting", locale)}</span
                                    >
                                </div>

                                <div class="log-line mt-2">
                                    <span class="text-text-disabled">$</span>
                                    <span class="text-accent-primary">_</span>
                                    <span class="terminal-cursor"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div
                        class="mt-3 flex items-center justify-between font-mono text-[0.65rem] uppercase tracking-wider text-text-disabled"
                    >
                        <span>{t("hero.figDev", locale)}</span>
                        <span>{t("hero.version", locale)}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
