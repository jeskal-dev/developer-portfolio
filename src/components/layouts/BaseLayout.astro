---
import "@styles/global.css";
import SEO from "@components/layouts/SEO.astro";
import Header from "@components/layouts/Header.astro";
import Footer from "@components/layouts/Footer.astro";
import { ClientRouter } from "astro:transitions";
import type { Locale } from "@i18n/index";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    type?: "website" | "article";
    publishedTime?: Date;
    noindex?: boolean;
    locale: Locale;
}
const props = Astro.props;
const locale = props.locale;
---

<!doctype html>
<html lang={locale}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />

        <!-- 🎯 CRITICAL: Theme script DEBE ir primero en el head -->
        <script is:inline>
            // Ejecutar inmediatamente para evitar FOUC
            (function () {
                try {
                    var stored = localStorage.getItem("theme");
                    var theme =
                        stored === "light" || stored === "dark"
                            ? stored
                            : "dark";
                    document.documentElement.setAttribute("data-theme", theme);

                    // ✅ CORRECCIÓN: Usar astro:after-swap en lugar de before-preparation
                    document.addEventListener("astro:after-swap", function () {
                        var newTheme = localStorage.getItem("theme");
                        var resolved =
                            newTheme === "light" || newTheme === "dark"
                                ? newTheme
                                : "dark";
                        document.documentElement.setAttribute(
                            "data-theme",
                            resolved,
                        );
                    });
                } catch (e) {
                    document.documentElement.setAttribute("data-theme", "dark");
                }
            })();
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@500;600;700;800&display=swap"
            rel="stylesheet"
        />

        <SEO {...props} locale={locale} />

        <ClientRouter />
    </head>
    <body class="min-h-screen flex flex-col">
        <div class="scroll-progress" id="scroll-progress" aria-hidden="true">
        </div>
        <Header locale={locale} />
        <main class="flex-1">
            <slot />
        </main>
        <Footer locale={locale} />

        <div
            id="scroll-to-top"
            class="fixed bottom-6 animate-bounce-subtle right-6 z-50 w-12 h-12 rounded-full flex items-center justify-center text-text-primary opacity-0 invisible translate-y-4 transition-all duration-300 ease-out-expo h hover:scale-110 focus:outline-none focus:ring-2 focus:ring-accent-primary focus:ring-offset-2 focus:ring-offset-bg"
            aria-label="Desplazarse"
            aria-hidden="true"
        >
            <svg
                id="scroll-arrow"
                xmlns="http://www.w3.org/2000/svg"
                width="30"
                height="30"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform duration-300 ease-out-expo"
                aria-hidden="true"
            >
                <path d="M6 9l6 6 6-6"></path>
            </svg>
        </div>

        <style is:inline>
            @keyframes bounce-subtle {
                0%,
                100% {
                    transform: translateY(0);
                }
                50% {
                    transform: translateY(-3px);
                }
            }
            .animate-bounce-subtle {
                animation: bounce-subtle 2s ease-in-out infinite;
            }
            #scroll-arrow.scrolled {
                transform: rotate(180deg);
            }
            @media (prefers-reduced-motion: reduce) {
                .animate-bounce-subtle {
                    animation: none;
                }
                #scroll-to-top {
                    transition: none;
                }
                #scroll-arrow {
                    transition: none;
                }
            }
        </style>

        <script>
            function setup() {
                const progress = document.getElementById("scroll-progress");
                const scrollToTopBtn = document.getElementById("scroll-to-top");
                const scrollArrow = document.getElementById("scroll-arrow");
                let hasScrolled = false;

                function updateProgress() {
                    if (!progress) return;
                    const scrollTop =
                        window.scrollY || document.documentElement.scrollTop;
                    const scrollHeight =
                        document.documentElement.scrollHeight -
                        document.documentElement.clientHeight;
                    const pct =
                        scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
                    progress.style.width = pct + "%";

                    if (scrollToTopBtn) {
                        const canScroll = scrollHeight > 0;

                        if (canScroll) {
                            scrollToTopBtn.classList.remove(
                                "opacity-0",
                                "invisible",
                                "translate-y-4",
                            );
                            scrollToTopBtn.classList.add(
                                "opacity-100",
                                "visible",
                                "translate-y-0",
                            );
                            scrollToTopBtn.setAttribute("aria-hidden", "false");
                        } else {
                            scrollToTopBtn.classList.add(
                                "opacity-0",
                                "invisible",
                                "translate-y-4",
                            );
                            scrollToTopBtn.classList.remove(
                                "opacity-100",
                                "visible",
                                "translate-y-0",
                            );
                            scrollToTopBtn.setAttribute("aria-hidden", "true");
                        }

                        if (scrollArrow) {
                            if (scrollTop > 50 && !hasScrolled) {
                                hasScrolled = true;
                                scrollArrow.classList.add("scrolled");
                                scrollToTopBtn.setAttribute(
                                    "aria-label",
                                    "Volver arriba",
                                );
                            } else if (scrollTop <= 50 && hasScrolled) {
                                hasScrolled = false;
                                scrollArrow.classList.remove("scrolled");
                                scrollToTopBtn.setAttribute(
                                    "aria-label",
                                    "Desplazarse",
                                );
                            }
                        }
                    }
                }

                const revealEls =
                    document.querySelectorAll<HTMLElement>(".reveal");
                const io = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("is-visible");
                                io.unobserve(entry.target);
                            }
                        });
                    },
                    { threshold: 0.15, rootMargin: "0px 0px -10% 0px" },
                );
                revealEls.forEach((el) => io.observe(el));

                let ticking = false;
                window.addEventListener(
                    "scroll",
                    () => {
                        if (!ticking) {
                            window.requestAnimationFrame(() => {
                                updateProgress();
                                ticking = false;
                            });
                            ticking = true;
                        }
                    },
                    { passive: true },
                );
                updateProgress();

                if (scrollToTopBtn) {
                    scrollToTopBtn.addEventListener("click", () => {
                        if (hasScrolled) {
                            window.scrollTo({ top: 0, behavior: "smooth" });
                        } else {
                            const scrollHeight =
                                document.documentElement.scrollHeight -
                                document.documentElement.clientHeight;
                            window.scrollTo({
                                top: scrollHeight,
                                behavior: "smooth",
                            });
                        }
                    });
                }

                document.addEventListener("astro:after-swap", () => {
                    const newReveal = document.querySelectorAll<HTMLElement>(
                        ".reveal:not(.is-visible)",
                    );
                    newReveal.forEach((el) => io.observe(el));
                    updateProgress();
                });
            }
            setup();
            document.addEventListener("astro:after-swap", setup);
        </script>
    </body>
</html>
