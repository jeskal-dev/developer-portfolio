# 🔧 Variables de entorno para el portafolio
# Copia este archivo a `.env` y ajusta los valores.

# Proveedor de analíticas (preparado, no implementado por defecto).
# Valores posibles: plausible | vercel | (vacío = sin analytics)
PUBLIC_ANALYTICS_PROVIDER=

# Si usas Plausible, especifica el dominio:
PUBLIC_PLAUSIBLE_DOMAIN=your-portfolio.example.com
GITHUB_TOKEN=
